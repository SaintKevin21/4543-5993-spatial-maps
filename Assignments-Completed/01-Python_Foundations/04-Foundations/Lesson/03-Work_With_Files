      "source": [
        "## 4. CSV Files"
      ],
      "id": "jaPD3hC6rrab"
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "iwNIl_Eqrrab"
      },
      "outputs": [],
      "source": [
        "import csv\n",
        "\n",
        "# Writing CSV\n",
        "rows = [[\"Name\", \"Score\"], [\"Alice\", 90], [\"Bob\", 85]]\n",
        "with open(\"scores.csv\", \"w\", newline=\"\") as f:\n",
        "    writer = csv.writer(f)\n",
        "    writer.writerows(rows)\n",
        "\n",
        "# Reading CSV\n",
        "with open(\"scores.csv\", \"r\") as f:\n",
        "    reader = csv.reader(f)\n",
        "    for row in reader:\n",
        "        print(row)"
      ],
      "id": "iwNIl_Eqrrab"
