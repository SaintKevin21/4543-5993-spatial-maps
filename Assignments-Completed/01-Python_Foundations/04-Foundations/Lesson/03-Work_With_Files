      "metadata": {
        "id": "a7pp7Nrwrraa"
      },
      "source": [
        "✅ **Your Turn**: Create a dictionary with your name and 2-3 favorite courses. Save it to `courses.json`, then read it back."
      ],
      "id": "a7pp7Nrwrraa"
    },
    {
      "cell_type": "code",
      "source": [
        "import json\n",
        "\n",
        "# Create dictionary with name and favorite courses\n",
        "my_courses = {\n",
        "    \"name\": \"Kevin Kangethe\",\n",
        "    \"favorite_courses\": [\"Data Science\", \"Python Programming\", \"Spatial Analysis\"]\n",
        "}\n",
        "\n",
        "# Write to JSON\n",
        "with open(\"courses.json\", \"w\") as f:\n",
        "    json.dump(my_courses, f)\n",
        "\n",
        "# Read back JSON\n",
        "with open(\"courses.json\", \"r\") as f:\n",
        "    loaded_courses = json.load(f)\n",
        "print(loaded_courses)"
      ],
      "metadata": {
        "id": "RLGZCnzLK5VN",
        "outputId": "6767fc38-23d4-4600-e8d2-a8bead4b1a5b",
