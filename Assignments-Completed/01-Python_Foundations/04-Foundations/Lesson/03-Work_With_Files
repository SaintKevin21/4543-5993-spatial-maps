      "source": [
        "## 2. Writing and Reading Text Files"
      ],
      "id": "8g3Wt3c8rraa"
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "PYM5F1I4rraa"
      },
      "outputs": [],
      "source": [
        "# Writing to a text file\n",
        "with open(\"example.txt\", \"w\") as f:\n",
        "    f.write(\"Hello, Jupyter!\\n\")\n",
        "    f.write(\"This is a text file.\\n\")"
      ],
      "id": "PYM5F1I4rraa"
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "vvXwUUa5rraa"
      },
      "outputs": [],
      "source": [
        "# Reading from a text file\n",
        "with open(\"example.txt\", \"r\") as f:\n",
        "    contents = f.read()\n",
        "contents"
      ],
      "id": "vvXwUUa5rraa"
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "cTU9uFjmrraa"
      },
      "source": [
        "✅ **Your Turn**: Write your name into a file called `me.txt`, then read it back and print the result."
      ],
      "id": "cTU9uFjmrraa"
    },
    {
      "cell_type": "code",
      "source": [
        "# Write your name to a file\n",
        "with open(\"me.txt\", \"w\") as f:\n",
        "    f.write(\"Kevin Kangethe\\n\")\n",
        "\n",
        "# Read it back\n",
        "with open(\"me.txt\", \"r\") as f:\n",
        "    result = f.read()\n",
        "print(result)"
      ],
