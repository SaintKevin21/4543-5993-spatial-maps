    },
    {
      "cell_type": "code",
      "source": [
        "import csv\n",
        "\n",
        "# Create CSV with 3 rows of data\n",
        "rows = [[\"Pet\", \"Age\", \"Type\"],\n",
        "        [\"Lucky\", 5, \"Dog\"],\n",
        "        [\"Bishop\", 3, \"Cat\"],\n",
        "        [\"Skywalker\", 1, \"Flying squirrel\"]]\n",
        "\n",
        "# Write CSV\n",
        "with open(\"pets.csv\", \"w\", newline=\"\") as f:\n",
        "    writer = csv.writer(f)\n",
        "    writer.writerows(rows)\n",
        "\n",
        "# Read CSV\n",
        "with open(\"pets.csv\", \"r\") as f:\n",
        "    reader = csv.reader(f)\n",
        "    for row in reader:\n",
        "        print(row)"
